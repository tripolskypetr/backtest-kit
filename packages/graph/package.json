    "typescript": "^5.0.0"
  },
  "dependencies": {
    "di-kit": "^1.1.1",
    "di-scoped": "^1.0.21",
    "functools-kit": "^2.0.1",
    "get-moment-stamp": "^1.1.2"
  },
  "publishConfig": {
