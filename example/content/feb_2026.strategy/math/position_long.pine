//@version=5
// ============================================================
// position_long.pine — LOCAL BOTTOM entry for BTCUSDT LONG
// Runs AFTER agent emits BUY signal on 8h block start
// Period reference: February 2026
// ============================================================
//
// Returns position=1 while the strategy should hold LONG.
// Returns position=0 before entry is found (waiting for local bottom).
// Exit is decided by the strategy: when this file returns 0 (agent
// switched signal away from BUY, so pine is no longer called).
//
// Entry: local bottom confirmed — previous bar's low equals the 60-bar
//        rolling low AND current bar closes above it.
// EntryPrice: low of the bar that formed the local bottom.
//
// Timeframe: 1m
// No var, no persistent state — fully stateless
// ============================================================

indicator("PositionLong Feb2026", overlay=true)

// --- Inputs ---
windowBars = input.int(60, "Entry window (bars)")

// --- Local bottom detection ---
windowLow = ta.lowest(low, windowBars)

// Local bottom confirmed: previous bar made the window low, current bar closes above it
localBottomConfirmed = low[1] <= windowLow and close > low[1]

// --- Stateless position tracking via barssince ---
bse = ta.barssince(localBottomConfirmed)

// Reconstruct entry price: low[1] at entry bar = low[bse + 1] now
epNow = low[bse + 1]

inPosition = not na(bse)

position = inPosition ? 1 : 0

// === OUTPUTS FOR BOT ===
plot(position,                       "Position",   display=display.data_window)
plot(position == 1 ? epNow : na,     "EntryPrice", display=display.data_window)

// === VISUAL ===
plot(close,                           "Price",   color=position == 1 ? color.green : color.gray, linewidth=2)
plotshape(localBottomConfirmed, "Long Entry", shape.triangleup, location.belowbar, color.green, size=size.small)
