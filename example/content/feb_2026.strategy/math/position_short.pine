//@version=5
// ============================================================
// position_short.pine — LOCAL TOP entry for BTCUSDT SHORT
// Runs AFTER agent emits SELL signal on 8h block start
// Period reference: February 2026
// ============================================================
//
// Returns position=1 while the strategy should hold SHORT.
// Returns position=0 before entry is found (waiting for local top).
// Exit is decided by the strategy: when this file returns 0 (agent
// switched signal away from SELL, so pine is no longer called).
//
// Entry: local top confirmed — previous bar's high equals the 60-bar
//        rolling high AND current bar closes below it.
// EntryPrice: high of the bar that formed the local top.
//
// Timeframe: 1m
// No var, no persistent state — fully stateless
// ============================================================

indicator("PositionShort Feb2026", overlay=true)

// --- Inputs ---
windowBars = input.int(60, "Entry window (bars)")

// --- Local top detection ---
windowHigh = ta.highest(high, windowBars)

// Local top confirmed: previous bar made the window high, current bar closes below it
localTopConfirmed = high[1] >= windowHigh and close < high[1]

// --- Stateless position tracking via barssince ---
bse = ta.barssince(localTopConfirmed)

// Reconstruct entry price: high[1] at entry bar = high[bse + 1] now
epNow = high[bse + 1]

inPosition = not na(bse)

position = inPosition ? 1 : 0

// === OUTPUTS FOR BOT ===
plot(position,                       "Position",   display=display.data_window)
plot(position == 1 ? epNow : na,     "EntryPrice", display=display.data_window)

// === VISUAL ===
plot(close,                           "Price",   color=position == 1 ? color.red : color.gray, linewidth=2)
plotshape(localTopConfirmed, "Short Entry", shape.triangledown, location.abovebar, color.red, size=size.small)
